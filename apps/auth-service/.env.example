NODE_ENV=development
GRPC_PORT=50051

# gRPC server transport security
# Defaults to false in all environments unless explicitly enabled.
GRPC_TLS_ENABLED=false
GRPC_TLS_KEY_PATH=
GRPC_TLS_CERT_PATH=
LOG_LEVEL=info

# Local Docker DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/notes_auth?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5434/notes_auth?schema=public

# Supabase (example)
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

JWT_ISSUER=notes-auth-service
JWT_AUDIENCE=notes-api-gateway
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# Dev-only fallback: app can generate keys if these are blank.
RSA_PRIVATE_KEY=
RSA_PUBLIC_KEY=