{
  "name": "@notes/auth-service",
  "version": "1.0.0",
  "private": true,
  "description": "Authentication service for Notes application",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist node_modules src/generated/prisma",
    "predev": "pnpm --filter @notes/shared-types run build",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --filter @notes/shared-types run build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "pnpm --filter @notes/shared-types run build && prisma generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prestart": "pnpm --filter @notes/shared-types run build",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@notes/shared-types": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^4.4.2"
  },
  "keywords": [],
  "author": "Pankaj Jangid",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  }
}
