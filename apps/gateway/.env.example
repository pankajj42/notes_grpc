NODE_ENV=development
PORT=3000
LOG_LEVEL=info

AUTH_SERVICE_URL=localhost:50051
NOTES_SERVICE_URL=localhost:50052

JWT_ISSUER=notes-auth-service
JWT_AUDIENCE=notes-api-gateway

# gRPC client transport security (gateway -> internal services)
# Defaults to false in all environments unless explicitly enabled.
GRPC_TLS_ENABLED=false
# Optional CA bundle when using private/self-signed certs.
GRPC_TLS_CA_PATH=

CORS_ORIGIN=http://localhost:5173
JWT_REFRESH_TTL_DAYS=30

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=