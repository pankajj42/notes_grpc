{
  "name": "@notes/gateway",
  "version": "1.0.0",
  "description": "Gateway service for Notes application",
  "private": true,
  "main": "index.js",
  "scripts": {
    "clean": "rimraf dist node_modules",
    "predev": "pnpm --filter @notes/shared-types run build && pnpm --filter @notes/grpc-clients run build",
    "dev": "tsx watch src/index.ts",
    "prebuild": "pnpm --filter @notes/shared-types run build && pnpm --filter @notes/grpc-clients run build",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "pnpm --filter @notes/shared-types run build && pnpm --filter @notes/grpc-clients run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@notes/grpc-clients": "workspace:*",
    "@notes/shared-types": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10"
  },
  "keywords": [],
  "author": "Pankaj Jangid",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1"
}
