NODE_ENV=development
GRPC_PORT=50052
LOG_LEVEL=info

# gRPC server transport security
# Defaults to false in all environments unless explicitly enabled.
GRPC_TLS_ENABLED=false
GRPC_TLS_KEY_PATH=
GRPC_TLS_CERT_PATH=

# Local Docker DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/notes_notes?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5433/notes_notes?schema=public

# Supabase (example)
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres