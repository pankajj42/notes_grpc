apiVersion: v1
kind: Secret
metadata:
  name: notes-secrets
  namespace: notes
type: Opaque
stringData:
  # Replace these values before applying in any shared environment.
  AUTH_DATABASE_URL: "postgresql://auth:secret@auth-db.notes.svc.cluster.local:5432/auth"
  AUTH_DIRECT_URL: "postgresql://auth:secret@auth-db.notes.svc.cluster.local:5432/auth"

  NOTES_DATABASE_URL: "postgresql://notes:secret@notes-db.notes.svc.cluster.local:5432/notes"
  NOTES_DIRECT_URL: "postgresql://notes:secret@notes-db.notes.svc.cluster.local:5432/notes"

  JWT_PRIVATE_KEY: |
    -----BEGIN RSA PRIVATE KEY-----
    REPLACE_ME
    -----END RSA PRIVATE KEY-----
  JWT_PUBLIC_KEY: |
    -----BEGIN RSA PUBLIC KEY-----
    REPLACE_ME
    -----END RSA PUBLIC KEY-----
