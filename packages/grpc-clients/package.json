{
  "name": "@notes/grpc-clients",
  "version": "1.0.0",
  "description": "gRPC clients for Notes application",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo node_modules",
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0"
  },
  "keywords": [],
  "author": "Pankaj Jangid",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1"
}
